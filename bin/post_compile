#!/usr/bin/env bash
# Heroku post-compile hook: download PLSDB CSVs and build SQLite DB
set -e

echo "-----> Building PLSDB SQLite database..."

mkdir -p data/raw

# Download CSV files from Figshare (PLSDB 2024_05_31_v2)
echo "       Downloading nuccore.csv..."
curl -sL -o data/raw/nuccore.csv "https://ndownloader.figshare.com/files/49859742"
echo "       Downloading typing.csv..."
curl -sL -o data/raw/typing.csv "https://ndownloader.figshare.com/files/49859745"
echo "       Downloading amr.tsv..."
curl -sL -o data/raw/amr.tsv "https://ndownloader.figshare.com/files/49859748"
echo "       Downloading taxonomy.csv..."
curl -sL -o data/raw/taxonomy.csv "https://ndownloader.figshare.com/files/49859727"
echo "       Downloading plasmidfinder.csv..."
curl -sL -o data/raw/plasmidfinder.csv "https://ndownloader.figshare.com/files/51520805"
echo "       Downloading typing_markers.csv..."
curl -sL -o data/raw/typing_markers.csv "https://ndownloader.figshare.com/files/49859751"
echo "       Downloading biosample.csv..."
curl -sL -o data/raw/biosample.csv "https://ndownloader.figshare.com/files/49859712"

# Download and filter proteins.csv for TA/phage/transposase genes
echo "       Downloading + filtering proteins.csv (637 MB → ~60 MB filtered)..."
curl -sL "https://ndownloader.figshare.com/files/49859766" | \
  python -c "
import sys, csv
reader = csv.DictReader(sys.stdin)
writer = None
ta_kw = ['toxin-antitoxin','antitoxin','addiction module','plasmid stabilization',
         'killer protein','post-segregational','type ii toxin']
ta_genes = {'rele','relb','higa','higb','mazf','maze','ccda','ccdb','pard','pare',
            'vapb','vapc','phd','doc','yoeb','yefm','mqsr','mqsa','hipa','hipb',
            'pema','pemk','pemi','hicb','hica','yafq','dina','brna','brnb'}
phage_kw = ['phage','prophage','bacteriophage','tail fiber','capsid',
            'terminase','portal protein','baseplate','holin','lysozyme']
trans_kw = ['transposase','integrase','recombinase','is element']
for row in reader:
    if writer is None:
        writer = csv.DictWriter(sys.stdout, fieldnames=reader.fieldnames)
        writer.writeheader()
    gene = (row.get('gene') or '').lower()
    product = (row.get('product') or '').lower()
    if (gene in ta_genes or any(kw in product for kw in ta_kw)
        or any(kw in product for kw in phage_kw)
        or any(kw in product for kw in trans_kw)):
        writer.writerow(row)
" > data/raw/pgap_filtered.csv
echo "       Filtered $(wc -l < data/raw/pgap_filtered.csv) PGAP rows"

echo "       Building SQLite database..."
python build_db.py

# Clean up raw files to save slug space
rm -rf data/raw

echo "-----> PLSDB database ready!"
